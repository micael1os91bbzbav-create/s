--// FUNÇÃO PROCESSAR SELEÇÃO DE MÚLTIPLAS CÂMERAS (COM ALL)
local function processarSelecaoCameras(texto)
	local selecionados = {}
	local textoUpper = string.upper(texto)
	
	if textoUpper == "ALL" then
		for i = 1, #cameras do
			table.insert(selecionados, i)
		end
	else
		for numero in string.gmatch(texto, "[^%s]+") do
			local num = tonumber(numero)
			if num and num >= 1 and num <= #cameras then
				table.insert(selecionados, num)
			end
		end
	end
	
	local unico = {}
	for _, v in ipairs(selecionados) do
		if not unico[v] then
			unico[v] = true
		end
	end
	
	local resultado = {}
	for k, _ in pairs(unico) do
		table.insert(resultado, k)
	end
	table.sort(resultado)
	
	return resultado
end

--// FUNÇÃO PARA REDIMENSIONAR AVIÃO
local function redimensionarAviao(cameraPart, novaEscala)
	if not cameraPart or not cameraPart.Parent then return end
	local model = cameraPart.Parent
	if not model:IsA("Model") then return end
	
	local escalaAntiga = model:GetAttribute("Escala") or 1
	local fator = novaEscala / escalaAntiga
	
	for _, parte in ipairs(model:GetChildren()) do
		if parte:IsA("Part") then
			parte.Size = parte.Size * fator
			local posRelativa = parte.CFrame.Position - cameraPart.CFrame.Position
			parte.CFrame = CFrame.new(cameraPart.CFrame.Position + (posRelativa * fator)) * (parte.CFrame - parte.CFrame.Position)
		end
	end
	
	model:SetAttribute("Escala", novaEscala)
end

--// FUNÇÃO CRIAR AVIÃO
local function criarAviao(position, tamanho)
	local escala = tamanho or 1
	
	local model = Instance.new("Model")
	model.Name = "Camera3D"
	model.Parent = workspace

	local corpo = Instance.new("Part")
	corpo.Size = Vector3.new(2 * escala, 0.8 * escala, 3 * escala)
	corpo.Material = Enum.Material.SmoothPlastic
	corpo.Color = Color3.fromRGB(245, 245, 245)
	corpo.Anchored = true
	corpo.CanCollide = false
	corpo.CFrame = CFrame.new(position)
	corpo.Parent = model

	local asa = Instance.new("Part")
	asa.Size = Vector3.new(4 * escala, 0.2 * escala, 1.5 * escala)
	asa.Material = Enum.Material.SmoothPlastic
	asa.Color = Color3.fromRGB(245, 245, 245)
	asa.Anchored = true
	asa.CanCollide = false
	asa.CFrame = corpo.CFrame * CFrame.new(0, 0.1 * escala, 0)
	asa.Parent = model

	local cauda = Instance.new("Part")
	cauda.Size = Vector3.new(0.4 * escala, 1 * escala, 1.2 * escala)
	cauda.Material = Enum.Material.SmoothPlastic
	cauda.Color = Color3.fromRGB(245, 245, 245)
	cauda.Anchored = true
	cauda.CanCollide = false
	cauda.CFrame = corpo.CFrame * CFrame.new(0, 0.6 * escala, -1.4 * escala)
	cauda.Parent = model

	local turbina = Instance.new("Part")
	turbina.Shape = Enum.PartType.Cylinder
	turbina.Size = Vector3.new(0.7 * escala, 0.7 * escala, 1 * escala)
	turbina.Material = Enum.Material.Metal
	turbina.Color = Color3.fromRGB(150, 150, 155)
	turbina.Anchored = true
	turbina.CanCollide = false
	turbina.CFrame = asa.CFrame * CFrame.new(0, -0.2 * escala, 0.5 * escala)
	turbina.Parent = model

	local cockpit = Instance.new("Part")
	cockpit.Shape = Enum.PartType.Cylinder
	cockpit.Size = Vector3.new(1 * escala, 0.6 * escala, 1 * escala)
	cockpit.Material = Enum.Material.Glass
	cockpit.Color = Color3.fromRGB(100, 150, 200)
	cockpit.Transparency = 0.3
	cockpit.Anchored = true
	cockpit.CanCollide = false
	cockpit.CFrame = corpo.CFrame * CFrame.new(0, 0.2 * escala, 1.2 * escala)
	cockpit.Parent = model

	model:SetAttribute("Escala", escala)
	model.PrimaryPart = corpo
	
	if avioesInvisiveis then
		for _, parte in ipairs(model:GetChildren()) do
			if parte:IsA("Part") then
				parte.Transparency = 1
			end
		end
	end
	
	return corpo
end

