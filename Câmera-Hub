--// DETECÇÃO DE PORTAIS
RunService.Heartbeat:Connect(function()
	if not scriptAtivado then return end
	
	local reference = getPlayerReference()
	if not reference then return end
	
	local hrp = reference:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	
	local playerPos = hrp.Position
	
	for numeroPortal, portal in pairs(portaisAtivos) do
		if portal and portal.Parent then
			local distancia = (portal.Position - playerPos).Magnitude
			local distanciaUsar = distanciaDeteccaoPortal
			
			local portalSelecionado = false
			for _, numSelecionado in ipairs(portaisSelecionados) do
				if numSelecionado == numeroPortal then
					portalSelecionado = true
					break
				end
			end
			
			if not portalSelecionado then
				distanciaUsar = 3
			end
			
			if distancia <= distanciaUsar then
				local numeroPar = (numeroPortal % 2 == 1) and numeroPortal + 1 or numeroPortal - 1
				local portalDestino = portaisAtivos[numeroPar]
				if portalDestino and portalDestino.Parent then
					teleportarJogador(portal, portalDestino)
				end
			end
		else
			portaisAtivos[numeroPortal] = nil
		end
	end
end)

