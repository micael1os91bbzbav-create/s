		for i, num in ipairs(numeros) do
			local selecionado = false
			for _, s in ipairs(portaisSelecionados) do
				if s == num then selecionado = true break end
			end
			if selecionado then
				table.insert(lista, "[" .. num .. "]✓")
			else
				table.insert(lista, num)
			end
		end
		texto = texto .. table.concat(lista, ", ")
	end
	portaisListaLabel:Set(texto)
