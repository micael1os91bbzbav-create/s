SectionControles:CreateButton({
	Name = "🔄 Trocar de Servidor",
	Callback = function()
		Rayfield:Notify({Title = "Trocando de Servidor", Content = "Procurando novo servidor...", Duration = 3})
		salvarEstadoScript()
		
		local PlaceId = game.PlaceId
		local HttpService = game:GetService("HttpService")
		local serversUrl = "https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
		
		local function encontrarServidor(cursor)
			local url = serversUrl
			if cursor then url = url .. "&cursor=" .. cursor end
			local success, result = pcall(function()
				return game:HttpGet(url)
			end)
			if success then return HttpService:JSONDecode(result) end
			return nil
		end
		
		local servidorEncontrado = nil
		local proximoCursor = nil
		
		repeat
			local dados = encontrarServidor(proximoCursor)
			if dados and dados.data then
				for _, servidor in pairs(dados.data) do
					if servidor.playing < servidor.maxPlayers and servidor.id ~= game.JobId then
						servidorEncontrado = servidor
						break
					end
				end
				proximoCursor = dados.nextPageCursor
			else
				break
			end
		until servidorEncontrado or not proximoCursor
		
		if servidorEncontrado then
			TeleportService:TeleportToPlaceInstance(PlaceId, servidorEncontrado.id, player)
		else
			Rayfield:Notify({Title = "Erro", Content = "Nenhum servidor disponível encontrado", Duration = 3})
		end
	end
})

