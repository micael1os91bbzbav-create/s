		for _, num in ipairs(numerosParaDeletar) do
			if portaisAtivos[num] then
				portaisAtivos[num]:Destroy()
				portaisAtivos[num] = nil
				liberarNumero(num)
				portaisDeletados = portaisDeletados + 1
			end
		end
		
		portaisSelecionados = {}
		atualizarListaPortais()
		
		if portaisDeletados > 0 then
			Rayfield:Notify({Title = "Portais Deletados", Content = portaisDeletados .. " portal(is) removido(s)!", Duration = 3})
		else
			Rayfield:Notify({Title = "Aviso", Content = "Nenhum portal encontrado", Duration = 3})
		end
	end
})

