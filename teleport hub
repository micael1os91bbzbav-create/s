-- ALTURA PADRÃO PARA OS DOIS (3 studs)
local DEFAULT_HEIGHT = 3

-- ============ TELEPORTE BLUE ============
blueButton.MouseButton1Click:Connect(function()
    local ladderPart = workspace.Map.Blue:GetChildren()[5].Ladder:GetChildren()[4]
    
    if not ladderPart or not ladderPart:IsA("BasePart") then
        ladderPart = workspace.Map.Blue:GetChildren()[5].Ladder:GetChildren()[1]
    end
    
    if not ladderPart or not ladderPart:IsA("BasePart") then
        warn("Escada Blue não encontrada!")
        return
    end
    
    local blockPosition = ladderPart.Position
    local blockCFrame = ladderPart.CFrame
    
    local sideDirection = blockCFrame.RightVector
    local sideDistance = 4.5
    
    -- Usando a altura padrão
    local sidePosition = Vector3.new(
        blockPosition.X + (sideDirection.X * sideDistance),
        blockPosition.Y + DEFAULT_HEIGHT,
        blockPosition.Z + (sideDirection.Z * sideDistance)
    )
    
    local lookAtBlock = CFrame.lookAt(sidePosition, blockPosition)
    local finalPosition = lookAtBlock
    
    local randomOffset = CFrame.new(
        math.random(-10, 10) / 100,
        math.random(-5, 5) / 100,
        math.random(-10, 10) / 100
    )
    finalPosition = finalPosition * randomOffset
    
    task.wait(math.random(50, 150) / 1000)
    
    local success = TeleportWithProtection(finalPosition)
    
    if success then
        blueButton.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
        task.wait(0.2)
        blueButton.BackgroundColor3 = Color3.fromRGB(0, 100, 255)
        print("✅ Teleportado BLUE! Altura: " .. DEFAULT_HEIGHT)
    else
        blueButton.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
        task.wait(0.2)
        blueButton.BackgroundColor3 = Color3.fromRGB(0, 100, 255)
    end
end)

